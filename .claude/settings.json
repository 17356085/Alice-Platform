{
  "hooks": {
    "SessionStart": [
      {
        "command": "echo 'TOKEN_SAVER: ①Grep>Read(省~1800tok) ②25轮收尾+交接状态 ③一件一事 ④大文件offset+limit分段 ⑤PAGE_INTERFACE.yaml优先(~200tok)而非PAGE_CONTEXT(~2000tok) ⑥避免重复Read同一文件'"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "command": "echo 'TIP: 非必要不Read全文件→优先Grep关键词 -C 2，省约1800 tokens。大文件Read时加offset+limit。'"
      }
    ],
    "Stop": [
      {
        "command": "echo '收尾: 写一句当前状态让下个会话能接上。格式: >> 状态: <module>/<page>, <完成项>, <待办项>'"
      }
    ]
  },
